# ──────────────────────────────────────────────────────────────
# PDF Auto-Completion Backend — Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and modify as needed.
# All variables are prefixed with PDFFILL_ to avoid conflicts.

# ── Server ──
PDFFILL_HOST=0.0.0.0
PDFFILL_PORT=8000
PDFFILL_MAX_WORKERS=1
PDFFILL_MAX_UPLOAD_SIZE_MB=50
PDFFILL_LOG_LEVEL=INFO

# ── Photo Detection ──
# Options: haar, dnn, auto (default: auto)
PDFFILL_PHOTO_DETECTION_STRATEGY=auto

# Haar Cascade tuning
PDFFILL_HAAR_SCALE_FACTOR=1.1
PDFFILL_HAAR_MIN_NEIGHBORS=5
PDFFILL_HAAR_MIN_SIZE_W=80
PDFFILL_HAAR_MIN_SIZE_H=80

# DNN tuning
PDFFILL_DNN_CONFIDENCE_THRESHOLD=0.5
PDFFILL_DNN_INPUT_SIZE=300

# Photo bounding box expansion (ratio of face bbox)
PDFFILL_PHOTO_EXPAND_TOP=0.3
PDFFILL_PHOTO_EXPAND_BOTTOM=0.5
PDFFILL_PHOTO_EXPAND_SIDES=0.4

# ── Signature Detection ──
PDFFILL_SIG_FOCUS_LOWER_PERCENT=0.6
PDFFILL_SIG_ADAPTIVE_BLOCK_SIZE=15
PDFFILL_SIG_ADAPTIVE_C=10
PDFFILL_SIG_MORPH_KERNEL_SIZE=5
PDFFILL_SIG_MIN_WIDTH=80
PDFFILL_SIG_MIN_HEIGHT=20
PDFFILL_SIG_MAX_WIDTH_RATIO=0.6
PDFFILL_SIG_ASPECT_RATIO_MIN=1.5
PDFFILL_SIG_ASPECT_RATIO_MAX=8.0
PDFFILL_SIG_SOLIDITY_MAX=0.7
PDFFILL_SIG_DENSITY_MAX=0.4
PDFFILL_SIG_CONFIDENCE_THRESHOLD=0.3

# ── PDF Conversion ──
PDFFILL_PDF_ZOOM_FACTOR=2.0

# ── Cleanup ──
PDFFILL_CLEANUP_TTL_HOURS=24
